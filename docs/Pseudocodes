PROCEDURE a_star_search
    Initialize a timer to track the duration
    Set the initial step count to 0
    Set the initial reward value to 0

    Create a copy of the environment to avoid altering the original
    Reset the environment copy and obtain the initial state

    Create a priority queue to store states, their costs, and corresponding paths, prioritized by the estimated total cost (cost + heuristic)
    Add the initial state with a cost of 0 and an empty path to the priority queue
    Create a set to track visited states
    Create a dictionary to store the predecessors of visited states
    Mark the initial state as visited
    Initialize a dictionary to store the cost to reach each state, starting with 0 for the initial state

    While the priority queue is not empty:
        Remove the state, current cost, and path with the lowest estimated total cost from the priority queue

        For each possible action from the current state:
            Simulate taking the action in the environment copy
            Observe the resulting state, reward, and completion status
            Calculate the cost to reach the new state as the current cost plus the cost of the action

            If the resulting state has not been visited or the calculated cost is lower than the previously recorded cost:
                Increment the step count
                Update the recorded cost for the resulting state
                Mark the resulting state as visited
                Record the current state and action as the predecessor of the resulting state
                Calculate the estimated total cost using the heuristic function
                Add the resulting state, cost, and updated path to the priority queue
                Add the obtained reward to the total reward

            If the goal is reached (completion status is true):
                Reconstruct the path from the initial state to the goal state using the predecessor information
                Display the results, including the algorithm name, duration, step count, path, and total reward
                End the search

    If no solution is found, indicate that no path to the goal could be discovered
END PROCEDURE






    

    def depth_first_search(self):
        """
        Performs Depth-First Search (DFS) to find a path.
        """
        begin_timer = time.time()
        total_no_of_steps = 0

        copy_env = deepcopy(self.env)
        initial_state = copy_env.unwrapped.s

        stack = LifoQueue()
        stack.put((initial_state,, 0))
        visited = set()
        visited.add(initial_state)

        while not stack.empty():
            state, path, cumulative_reward = stack.get()

            actions = list(range(self.env.action_space.n))
            for action in actions:
                copy_env.unwrapped.s = state
                total_no_of_steps += 1

                new_state, reward, done, _, _ = copy_env.step(action)

                new_cumulative_reward = cumulative_reward + reward

                if done:
                    self.results(
                        actions_taken=path + [action],
                        reward=new_cumulative_reward,
                        steps=total_no_of_steps,
                        time=time.time() - begin_timer,
                        algo_name="Depth First Search",
                        separator=True
                    )
                    return

                if new_state not in visited:
                    visited.add(new_state)
                    stack.put((new_state, path + [action], new_cumulative_reward))

        print("No solution found")

    def breadth_first_search(self):
        """
        Performs Breadth-First Search (BFS) to find a path.
        """
        begin_timer = time.time()
        total_no_of_steps = 0

        copy_env = deepcopy(self.env)
        initial_state = copy_env.unwrapped.s

        queue = Queue()
        queue.put((initial_state,, 0))
        visited = set()
        visited.add(initial_state)

        while not queue.empty():
            state, path, cumulative_reward = queue.get()

            actions = list(range(self.env.action_space.n))
            for action in actions:
                copy_env.unwrapped.s = state
                total_no_of_steps += 1

                new_state, reward, done, _, _ = copy_env.step(action)

                new_cumulative_reward = cumulative_reward + reward

                if done:
                    self.results(
                        actions_taken=path + [action],
                        reward=new_cumulative_reward,
                        steps=total_no_of_steps,
                        time=time.time() - begin_timer,
                        algo_name="Breadth First Search",
                        separator=True
                    )
                    return

                if new_state not in visited:
                    visited.add(new_state)
                    queue.put((new_state, path + [action], new_cumulative_reward))


        print("No solution found")

    @staticmethod
    def location_string(loc):
        """
        Converts a location index to a human-readable string.

        Args:
            loc (int): The location index.

        Returns:
            str: The location string.
        """
        if loc == 0:
            return "Red"
        if loc == 1:
            return "Green"
        if loc == 2:
            return "Yellow"
        if loc == 3:
            return "Blue"
        if loc == 4:
            return "In taxi"
        raise AssertionError("Unreachable code")

    @staticmethod
    def action_string(action):
        """
        Converts an action index to a human-readable string.

        Args:
            action (int): The action index.

        Returns:
            str: The action string.
        """
        if action == 0:
            return "SOUTH"
        if action == 1:
            return "NORTH"
        if action == 2:
            return "EAST"
        if action == 3:
            return "WEST"
        if action == 4:
            return "PICK UP"
        if action == 5:
            return "DROP OFF"
        raise AssertionError("Unreachable code")

    @staticmethod
    def location_coordinates(loc: int) -> tuple[int, int]:
        """
        Gets the coordinates of a location.

        Args:
            loc (int): The location index.

        Returns:
            tuple[int, int]: The coordinates of the location.
        """
        # Red
        if loc == 0:
            return (0, 0)

        # Green
        if loc == 1:
            return (0, 4)

        # Yellow
        if loc == 2:
            return (4, 0)

        # Blue
        if loc == 3:
            return (4, 3)

        raise AssertionError(f"Unknown location: {loc}")

    @classmethod
    def print_initial_env(cls, env):
        """
        Prints the initial state of the environment.

        Args:
            env (gym.Env): The Gym environment.
        """
        print(env.render().strip())
        [taxi_row, taxi_col, pass_loc, dest] = env.unwrapped.decode(env.unwrapped.s)
        print(f"Taxi position: (row {taxi_row}, col {taxi_col})")
        print(f"Passenger position: {cls.location_string(pass_loc)}")
        print(f"Destination: {cls.location_string(dest)}")

